# =========================
# Application
# =========================

SECRET_KEY=change_this_secret_key
PORT=8000
HOST=0.0.0.0
FLASK_DEBUG=1

# =========================
# MongoDB Configuration
# =========================

MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=your_mongo_user
MONGO_PASSWORD=your_mongo_password
MONGO_DB=BadBoys
MONGO_AUTH_SOURCE=admin

# MongoDB Connection Pool
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=10
MONGO_SERVER_SELECTION_TIMEOUT=5000
MONGO_CONNECT_TIMEOUT=10000
MONGO_SOCKET_TIMEOUT=20000

# TLS / SSL
MONGO_TLS=true
MONGO_TLS_CA_FILE=path/to/ca.pem
MONGO_TLS_CERT_FILE=path/to/server.pem
MONGO_TLS_ALLOW_INVALID=true

# =========================
# CORS
# =========================

CORS_ORIGINS=["http://localhost:5173"]

# =========================
# Logging
# =========================

LOG_LEVEL=DEBUG

# =========================
# Key Rotation
# =========================

KEY_ROTATION_INTERVAL=60

# =========================
# Hashing
# =========================

PBKDF2_ITERATIONS=100000
PBKDF2_ALGORITHM=sha256
SEZAR_PASSES=2

# =========================
# Session Cookie
# =========================

SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
SESSION_TYPE=filesystem
SESSION_FILE_DIR=./flask_session
PERMANENT_SESSION_LIFETIME=3600

# =========================
# CSRF
# =========================

CSRF_ENABLED=true
CSRF_TIME_LIMIT=3600

CSRF_COOKIE_SECURE=false
CSRF_COOKIE_HTTPONLY=false
CSRF_COOKIE_SAMESITE=Strict

# =========================
# Socket.IO
# =========================

SOCKETIO_CORS_ALLOWED_ORIGINS=http://localhost:5173
SOCKETIO_ASYNC_MODE=eventlet

# =========================
# Bruteforce Handler
# =========================

USER_WARN_LOCK=3
USER_TEMP_LOCK_TIME=900
USER_HARD_LOCK=6

IP_WARN_LOCK=10
IP_TEMP_LOCK_TIME=1800
IP_HARD_LOCK=30
IP_HARD_LOCK_TIME=86400

# =========================
# Password Policy
# =========================

PASSWORD_MIN_LENGTH=12
PASSWORD_MAX_LENGTH=72
USERNAME_MIN_LENGTH=10

# =========================
# Data Fetching
# =========================

DATA_FETCH_INTERVAL=600
HACKER_NEWS_API_URL=https://hacker-news.firebaseio.com/v0
HACKER_NEWS_HTML_URL=https://news.ycombinator.com/news
MAX_STORIES_FETCH=20

# =========================
# Redis Configuration
# =========================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_MAX_CONNECTIONS=50

# =========================
# Rate Limiting
# =========================

RATELIMIT_ENABLED=true
RATELIMIT_STORAGE_URL=redis://localhost:6379/0

RATELIMIT_DEFAULT=200/hour;50/minute
RATELIMIT_LOGIN=5/minute;20/hour
RATELIMIT_REGISTER=3/minute;10/hour
RATELIMIT_API=100/minute;1000/hour

RATELIMIT_HEADERS_ENABLED=true
RATELIMIT_SWALLOW_ERRORS=true
