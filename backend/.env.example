FLASK_ENV=live
# SECRETS - Production için değiştir!
SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here
MASTER_3DES_KEY=your_master_3des_key_here
PORT=5000
HOST=0.0.0.0
FLASK_DEBUG=0
# MONGODB
MONGO_HOST=ceyizator-mongo
MONGO_PORT=27017
MONGO_USER=your_mongo_user
MONGO_PASSWORD=your_mongo_password
MONGO_DB=your_mongo_db
MONGO_AUTH_SOURCE=your_mongo_auth_source
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=10
MONGO_SERVER_SELECTION_TIMEOUT=5000
MONGO_CONNECT_TIMEOUT=10000
MONGO_SOCKET_TIMEOUT=20000
# TLS
MONGO_TLS=true
MONGO_TLS_CA_FILE=/certs/ca.pem
MONGO_TLS_CERT_FILE=/certs/server.pem
MONGO_TLS_ALLOW_INVALID=true
# CORS
CORS_ORIGINS=https://www.yourdomain.com,https://yourdomain.com
# LOGGING
LOG_LEVEL=WARNING
# KEY ROTATION
KEY_ROTATION_INTERVAL=600
# HASHING
PBKDF2_ITERATIONS=100000
PBKDF2_ALGORITHM=sha256
SEZAR_PASSES=2
# SESSION
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
SESSION_TYPE=filesystem
SESSION_FILE_DIR=./flask_session
PERMANENT_SESSION_LIFETIME=3600
# SOCKET.IO
SOCKETIO_CORS_ALLOWED_ORIGINS=https://www.yourdomain.com,https://yourdomain.com
SOCKETIO_ASYNC_MODE=threading
# BRUTEFORCE
USER_WARN_LOCK=7
USER_TEMP_LOCK_TIME=900
USER_HARD_LOCK=10
IP_WARN_LOCK=100
IP_TEMP_LOCK_TIME=1800
IP_HARD_LOCK=250
IP_HARD_LOCK_TIME=86400
# PASSWORD POLICY
PASSWORD_MIN_LENGTH=12
PASSWORD_MAX_LENGTH=72
USERNAME_MIN_LENGTH=3
# DATA FETCHING
DATA_FETCH_INTERVAL=600
HACKER_NEWS_API_URL=https://hacker-news.firebaseio.com/v0
HACKER_NEWS_HTML_URL=https://news.ycombinator.com/news
MAX_STORIES_FETCH=20
# REDIS
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your_redis_password
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_MAX_CONNECTIONS=50
# RATE LIMITING
RATELIMIT_ENABLED=true
RATELIMIT_STORAGE_URL=redis://redis:6379/0
RATELIMIT_DEFAULT=200/hour;50/minute
RATELIMIT_LOGIN=10/minute;30/hour
RATELIMIT_REGISTER=5/minute;20/hour
RATELIMIT_API=300/minute;5000/hour
RATELIMIT_CEYIZ_WRITE=30/minute
RATELIMIT_CEYIZ_READ=120/minute
RATELIMIT_HEADERS_ENABLED=true
RATELIMIT_SWALLOW_ERRORS=true
# JWT
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=604800
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=Lax
